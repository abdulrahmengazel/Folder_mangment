create-jdbc-connection-pool --datasourceclassname org.postgresql.ds.PGSimpleDataSource --restype javax.sql.DataSource --property serverName=${DB_HOST}:portNumber=${DB_PORT}:databaseName=${DB_NAME}:user=${DB_USER}:password=${DB_PASSWORD}:sslmode=require folder_mgmt_pool
create-jdbc-resource --connectionpoolid folder_mgmt_pool jdbc/CloudDrivePu